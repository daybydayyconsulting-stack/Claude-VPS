# ============================================================
# Claude VPS — Environment Configuration
# Copy this file to .env and fill in your real values
# NEVER commit .env to git
# ============================================================

# --- Meta Ads API ---
# Get these from: https://developers.facebook.com/apps/
META_APP_ID=your_app_id_here
META_APP_SECRET=your_app_secret_here

# Long-lived access token (60 days) or System User token (never expires)
# Generate at: https://developers.facebook.com/tools/explorer/
META_ACCESS_TOKEN=your_access_token_here

# Ad Account ID — format: act_XXXXXXXXXX
# Find it at: https://business.facebook.com/settings/ad-accounts
META_AD_ACCOUNT_ID=act_your_account_id_here

# --- API Security ---
# Generate a strong random key: python3 -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=generate_a_strong_random_key_here

# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=false
